    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.5"
